{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,  // ajuste de posição
    "experimentalDecorators": true, // ajuste de posição
    "outDir": "./src"
  },
  "include": ["src"],
  "allowJs": true
}
